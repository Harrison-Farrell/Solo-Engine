---
SystemHeaders: false
HeaderFilterRegex: 'include|src'
ExcludeHeaderFilterRegex: 'llvm|clang|googletest|gmock|gtest'
FormatStyle: "file"
WarningsAsErrors: ''
Checks:
    '
    -*,
    bugprone-*,
    clang-analyzer-*,
    concurrency-*,
    cppcoreguidelines-*,
    misc-*,
    modernize-*,
    -modernize-concat-nested-namespaces,
    -modernize-return-braced-init-list,
    -modernize-use-nodiscard,
    -modernize-use-trailing-return-type,
    performance-*,
    portability-*,
    readability-*
    '
HeaderFileExtensions:
  - ''
  - h
  - hh
  - hpp
  - hxx
ImplementationFileExtensions:
  - c
  - cc
  - cpp
  - cxx
CheckOptions:
  readability-identifier-naming.PrivateMemberPrefix: 'm'
  readability-identifier-naming.PrivateMemberCase: 'CamelBack'
  readability-identifier-naming.ClassMemberCase: 'CamelCase'
  readability-identifier-naming.ClassMethodCase: 'CamelCase'
  readability-identifier-naming.FunctionCase: 'CamelCase' 
  readability-identifier-naming.LocalVariableCase: 'lower_case'
  readability-identifier-naming.ParameterCase: 'lower_case'
  readability-identifier-naming.StaticConstexprVariablePrefix: 'k'
  readability-identifier-naming.StaticConstantCase: 'CamelCase'
...

